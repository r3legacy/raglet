   "source": [
    "# raglet — fully local / offline\n",
    "\n",
    "Run the whole pipeline on your own machine: local embeddings via `sentence-transformers` and local generation via `ollama`. No API keys required."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "from raglet import RAG, RAGConfig\n",
    "\n",
    "rag = RAG(RAGConfig(\n",
    "    embedder=\"local\",   # downloads a small model on first use\n",
    "    llm=\"ollama\",       # requires `ollama run llama3.2` running\n",
    "    store_path=\"./.store\",\n",
    "))\n",
    "rag.ingest(\"./docs\")\n",
    "\n",
    "result = rag.ask(\"Summarize the refund policy.\")\n",
    "print(result[\"answer\"])\n",
    "for s in result[\"sources\"]:\n",
    "    print(\"-", s[\"source\"], f'({s[\"score\"]:.3f})')"
   ]
  }
 ],
